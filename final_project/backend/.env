# ─────────────────────────────────────────────────────────────
# ExamPro LMS SaaS — Environment Variables
# Copy this file to backend/.env and fill in your values
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5000

# JWT
JWT_SECRET=your_very_long_and_random_jwt_secret_key_here

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=exam_platform

# ── Global SMTP (used by super admin and fallback) ────────────
# NOTE: Admin sites use their OWN SMTP (configured in admin panel).
# This global SMTP is ONLY for: super admin emails, and fallback
# if an admin has not configured their own SMTP yet.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=ExamPro
SMTP_FROM_EMAIL=noreply@exampro.ng

# ── Global Payment Gateways (platform-level fallback) ─────────
# Admin sites use their OWN gateway keys (configured in admin panel)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public

FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-your_flutterwave_secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE-your_flutterwave_public
FLUTTERWAVE_SECRET_HASH=your_flutterwave_webhook_hash

STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── Webhook URLs ──────────────────────────────────────────────
# Register these in your payment gateway dashboards:
# Paystack:     POST https://yourdomain.com/api/payments/webhook/paystack
# Flutterwave:  POST https://yourdomain.com/api/payments/webhook/flutterwave
# Stripe:       POST https://yourdomain.com/api/payments/webhook/stripe

# ── Super Admin ───────────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@exampro.ng
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# ── Anthropic AI (Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=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